# ITL EOC Assistant — environment configuration
# Copy this file to ".env" and fill in your key. The .env file is gitignored.

# Required to turn the LLM ON. Without it, /ask returns the deterministic cards.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: which Claude model answers. Default is claude-opus-4-8 (most capable).
# For lower cost/latency you can switch to claude-sonnet-4-6 or claude-haiku-4-5.
# EOC_MODEL=claude-opus-4-8

# Optional: server port (default 3000)
# PORT=3000

# Premium full-EOC review — gate + limits.
# Comma-separated valid license keys. If unset, premium is OPEN (dev mode).
# (Swap this check for Stripe/account verification in server.mjs premiumOk().)
# PREMIUM_LICENSE_KEYS=key-abc,key-def
# Max rows reviewed per upload (transparent cap; default 50, hard max 400).
# REVIEW_MAX_ROWS=50

# Leads — admin key required to download the captured-leads CSV (/leads/export).
# If unset, the export is disabled (403). The entry gate itself always works.
# LEADS_ADMIN_KEY=change-me
