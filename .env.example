# ITL EOC Assistant — environment configuration.
# Copy to ".env" (gitignored) and fill in. On Render, set these in the service's
# Environment settings instead of a committed file. NEVER commit real secrets.

# --- Claude / LLM (required to turn the LLM on) ---
ANTHROPIC_API_KEY=
# Optional model override (default claude-opus-4-8):
# EOC_MODEL=claude-opus-4-8

# --- Morning (Greeninvoice) Payments ---------------------------------------------
# Sandbox API key (ID) + Secret from Morning → Settings → API. All calls are backend-only.
# Switch GREENINVOICE_ENV to "production" + use the live key/secret to go live (config only).
GREENINVOICE_API_KEY_ID=
GREENINVOICE_API_SECRET=
GREENINVOICE_ENV=sandbox
# Shared secret you set in Morning's Webhooks tab — used to verify webhook authenticity.
GREENINVOICE_WEBHOOK_SECRET=
# Clearing terminal / payment plugin ID (from Morning). REQUIRED for payment forms — without it
# the API returns errorCode 2600 "no active clearing terminal". Sandbox + production each have their own.
GREENINVOICE_PLUGIN_ID=

# Prices are VAT-INCLUSIVE whole shekels (the customer pays these; ex-VAT is derived = ÷1.18):
# GREEN_PRICE_SUB=115        # monthly membership /mo (recurring)
# GREEN_PRICE_QUESTIONS=6    # per single question
# GREEN_PRICE_REVIEW=103     # one-time full EOC review
# GREEN_PRICE_CONSULT=673    # 30-minute expert call
# VAT_RATE=0.18

# Public site URL — used to build payment success/cancel + webhook URLs.
BASE_URL=https://eoc-assistant.onrender.com

# --- Email (Resend HTTP API — works on Render, which blocks outbound SMTP) --------
RESEND_API_KEY=
RESEND_FROM=EOC Assistant <onboarding@resend.dev>
BUG_NOTIFY_EMAIL=
EXPERT_NOTIFY_EMAIL=

# --- Google Sheets lead mirror (Apps Script web-app URL) -------------------------
SHEETS_WEBHOOK_URL=

# --- Admin / owner bypass (unlimited questions + free reviews) -------------------
ADMIN_KEY=

# --- Free-plan question cap per email (default 5) --------------------------------
FREE_QUERY_LIMIT=5
